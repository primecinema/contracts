{
  "name": "@primecinema/contracts",
  "version": "1.2.5",
  "description": "Protobuf definition and generated TypeScript types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "generate": "protoc -I ./proto ./proto/*.proto --ts_proto_out=./gen/ts --ts_proto_opt=nestJs=true,package=omit"
  },
  "files": [
    "dist",
    "proto",
    "gen"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.13",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.11.2"
  },
  "devDependencies": {
    "@primecinema/core": "^1.0.4",
    "@types/node": "^25.2.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
